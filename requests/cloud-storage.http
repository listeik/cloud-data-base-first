@baseUrl = http://localhost:8080
@username = demo_user
@password = strong-password

### Register and save the session cookie
POST {{baseUrl}}/api/auth/sign-up
Content-Type: application/json

{
  "username": "{{username}}",
  "password": "{{password}}"
}

> {% client.global.set("sessionCookie", response.headers.valueOf("Set-Cookie").split(";")[0]); %}

### Sign in when the user already exists
POST {{baseUrl}}/api/auth/sign-in
Content-Type: application/json

{
  "username": "{{username}}",
  "password": "{{password}}"
}

> {% client.global.set("sessionCookie", response.headers.valueOf("Set-Cookie").split(";")[0]); %}

### Current user
GET {{baseUrl}}/api/user/me
Cookie: {{sessionCookie}}

### Create a directory
POST {{baseUrl}}/api/directory?path=documents/
Cookie: {{sessionCookie}}

### Upload a text file
POST {{baseUrl}}/api/resource?path=documents/
Cookie: {{sessionCookie}}
Content-Type: multipart/form-data; boundary=cloud-boundary

--cloud-boundary
Content-Disposition: form-data; name="files"; filename="hello.txt"
Content-Type: text/plain

Hello from Cloud Data Base
--cloud-boundary--

### List a directory
GET {{baseUrl}}/api/directory?path=documents/
Cookie: {{sessionCookie}}

### List a directory page
GET {{baseUrl}}/api/directory/page?path=documents/&page=0&size=20
Cookie: {{sessionCookie}}

### Search resources
GET {{baseUrl}}/api/resource/search?query=hello
Cookie: {{sessionCookie}}

### Search resources with pagination
GET {{baseUrl}}/api/resource/search/page?query=hello&page=0&size=20
Cookie: {{sessionCookie}}

### Move or rename a resource
GET {{baseUrl}}/api/resource/move?from=documents/hello.txt&to=documents/renamed.txt
Cookie: {{sessionCookie}}

### Download a resource
GET {{baseUrl}}/api/resource/download?path=documents/renamed.txt
Cookie: {{sessionCookie}}

### Delete a resource
DELETE {{baseUrl}}/api/resource?path=documents/renamed.txt
Cookie: {{sessionCookie}}

### Sign out
POST {{baseUrl}}/api/auth/sign-out
Cookie: {{sessionCookie}}
